class Solution {
    public int[] minOperations(String boxes) {
        int n = boxes.length();
        int[] answer = new int[n];

        int ballsLeft = 0;
        int opsLeft = 0;
        for (int i = 0; i < n; i++) {
            answer[i] += opsLeft;
            if (boxes.charAt(i) == '1') {
                ballsLeft++;
            }
            opsLeft += ballsLeft;
        }

        int ballsRight = 0;
        int opsRight = 0;
        for (int i = n - 1; i >= 0; i--) {
            answer[i] += opsRight;
            if (boxes.charAt(i) == '1') {
                ballsRight++;
            }
            opsRight += ballsRight;
        }

        return answer;
    }
}
